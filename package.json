{
  "name": "hearth",
  "private": true,
  "description": "Hearth — Flametrench v0.2 reference application (customer support inbox).",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm --filter '@hearth/*' run -r typecheck",
    "build": "pnpm --filter '@hearth/web' run build && pnpm --filter '@hearth/node' run build",
    "test": "pnpm --filter '@hearth/e2e' run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}

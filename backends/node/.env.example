# Hearth Node backend — copy to .env for local dev.
PORT=5001
DATABASE_URL=postgres://hearth:hearth@localhost:5501/hearth

# SMTP (mailpit by default — see docker-compose.yml at repo root).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=hearth@localhost

# Public base URL the SPA is served from (used to build share-link emails).
HEARTH_PUBLIC_BASE_URL=http://localhost:3000

# Hearth Go backend — copy to .env for local dev.
PORT=5005
DATABASE_URL=postgres://hearth:hearth@localhost:5505/hearth

# SMTP (mailpit by default — see docker-compose.yml at repo root).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=hearth@localhost

# Public base URL the web app is served from. Used when minting share
# links and verification URLs inside outbound email.
HEARTH_PUBLIC_BASE_URL=http://localhost:3000

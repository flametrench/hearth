PORT=5003
DATABASE_URL=postgresql://hearth:hearth@localhost:5503/hearth
# NOTE on macOS + Docker Desktop: mailpit's SMTP listener at [::]:1025 only
# responds to IPv6 from the host (the IPv4 path through Docker's port
# forwarder hangs without a greeting). Use ::1 here, not 127.0.0.1 or
# localhost (which on macOS Python prefers IPv4-first).
SMTP_HOST=::1
SMTP_PORT=1025
SMTP_FROM=hearth@localhost
HEARTH_PUBLIC_BASE_URL=http://localhost:3000
